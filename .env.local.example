# Copy to `.env.local` and fill in your values.
# Do not commit `.env.local`.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=

# WATI WhatsApp (server-side; used by /api/wati/send-template)
WATI_BASE_URL=
WATI_API_KEY=

# Slack (server-side DMs via API routes)
SLACK_BOT_TOKEN=

# Vercel Cron: set same value in Vercel env; weekly reminder GET sends Authorization: Bearer CRON_SECRET
CRON_SECRET=
